# Environment variables for life-reborn
ENV=dev

# V1.8 Wave B axes 1+6 — datasheet-mcp HTTP surface.
# Container DNS in prod compose; localhost+8023 in dev (8022 is cad-mcp).
DATASHEET_MCP_HTTP_URL=http://datasheet-mcp:8023
# Bearer comes from /home/electron/.secrets/saillant-shared.env in prod.
DATASHEET_BEARER=
